#!/usr/bin/env bash
# .claude/hooks/pre-commit-secrets — Intercept accidental secret commits
#
# Scans staged files for common secret patterns.
# Exit 1 blocks the commit with a clear message.

set -euo pipefail

SECRETS_PATTERN='(PAYPAL_CLIENT_SECRET|CLOUDFLARE_API_TOKEN|GH_TOKEN|GITHUB_TOKEN|sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|wrangler.*secret|-----BEGIN (RSA |EC )?PRIVATE KEY)'

# Check staged files only (not the full working tree)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

VIOLATIONS=""
while IFS= read -r file; do
  # Skip binary files and this hook itself
  if file "$file" | grep -q "binary" 2>/dev/null; then
    continue
  fi
  if [ "$file" = ".claude/hooks/pre-commit-secrets" ]; then
    continue
  fi

  # Check staged content (not working tree)
  MATCHES=$(git show ":$file" 2>/dev/null | grep -nEi "$SECRETS_PATTERN" || true)
  if [ -n "$MATCHES" ]; then
    VIOLATIONS="${VIOLATIONS}\n  ${file}:\n${MATCHES}\n"
  fi
done <<< "$STAGED_FILES"

if [ -n "$VIOLATIONS" ]; then
  echo "=========================================="
  echo "  BLOCKED: Potential secrets detected"
  echo "=========================================="
  echo -e "$VIOLATIONS"
  echo ""
  echo "If these are false positives, use:"
  echo "  git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
