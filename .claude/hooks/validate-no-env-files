#!/usr/bin/env bash
# .claude/hooks/validate-no-env-files — Block .env files from being staged
#
# Prevents .env, .env.local, credentials.json, and similar files
# from ever being committed to the repository.

set -euo pipefail

BLOCKED_PATTERNS=(
  '\.env$'
  '\.env\.local$'
  '\.env\.production$'
  'credentials\.json$'
  'service-account.*\.json$'
  '\.pem$'
  '\.p12$'
  '\.key$'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

BLOCKED=""
for pattern in "${BLOCKED_PATTERNS[@]}"; do
  MATCHES=$(echo "$STAGED_FILES" | grep -Ei "$pattern" || true)
  if [ -n "$MATCHES" ]; then
    BLOCKED="${BLOCKED}\n  ${MATCHES}"
  fi
done

if [ -n "$BLOCKED" ]; then
  echo "=========================================="
  echo "  BLOCKED: Sensitive files detected"
  echo "=========================================="
  echo -e "$BLOCKED"
  echo ""
  echo "These file types must never be committed."
  echo "Add them to .gitignore instead."
  echo ""
  exit 1
fi

exit 0
