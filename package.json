{
  "name": "chinesezodiacyear.com",
  "version": "2.0.0",
  "type": "module",
  "description": "Encyclopaedia, directory, and news platform for Chinese zodiac, BaZi, feng shui, and traditional Chinese culture.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npx @11ty/eleventy",
    "serve": "npx @11ty/eleventy --serve --port=8080",
    "dev": "npx @11ty/eleventy --serve --port=8080",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev",
    "infra:bootstrap": "./scripts/bootstrap-d1-r2.sh",
    "infra:d1:create": "npx --no-install wrangler d1 create czy-main",
    "infra:r2:create": "npx --no-install wrangler r2 bucket create czy-reports",
    "infra:list": "npx --no-install wrangler d1 list && npx --no-install wrangler r2 bucket list",
    "infra:migrations:check": "bash ./scripts/check-migrations.sh",
    "infra:migrations:apply:local": "npx --no-install wrangler d1 migrations apply ${D1_DATABASE_BINDING:-DB} --local",
    "infra:migrations:apply:remote": "npx --no-install wrangler d1 migrations apply ${D1_DATABASE_BINDING:-DB} --remote",
    "infra:repositories:check": "bash ./scripts/check-no-sql-in-services.sh"
  },
  "keywords": [
    "chinese-zodiac",
    "bazi",
    "fengshui",
    "eleventy"
  ],
  "author": "Chinese Zodiac Year",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "esbuild": "^0.27.4",
    "vitest": "^4.1.0",
    "wrangler": "^4.71.0"
  }
}
