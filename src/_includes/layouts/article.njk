---js
{
  layout: "layouts/base.njk"
}
---
{% include "partials/breadcrumbs.njk" %}
{% include "partials/hero.njk" %}

<div class="article-layout">
  <article class="article-content">
    {% if showShareButtons !== false %}
      {% include "partials/share-buttons.njk" %}
    {% endif %}

    {{ content | safe }}

    {% if faq %}
    <section id="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-section">
        {%- for item in faq %}
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">{{ item.q }}</button>
          <div class="faq-answer">
            <p>{{ item.a }}</p>
          </div>
        </div>
        {%- endfor %}
      </div>
    </section>
    {% endif %}
  </article>

  {% if sidebar !== false %}
  <aside class="article-sidebar">
    {% if toc %}
    <div class="sidebar-widget">
      <h4>Contents</h4>
      <ul class="toc-list">
        {%- for item in toc %}
        <li><a href="#{{ item.id }}">{{ item.label }}</a></li>
        {%- endfor %}
      </ul>
    </div>
    {% endif %}

    {% if relatedArticles %}
    <div class="sidebar-widget">
      <h4>Related Articles</h4>
      {%- for item in relatedArticles %}
      <a href="{{ item.url }}" style="display:block;margin-bottom:0.5rem;">{{ item.label }}</a>
      {%- endfor %}
    </div>
    {% endif %}

    {% if sidebarExplore %}
    <div class="sidebar-widget">
      <h4>Explore</h4>
      {%- for item in sidebarExplore %}
      <a href="{{ item.url }}" style="display:block;margin-bottom:0.5rem;">{{ item.label }}</a>
      {%- endfor %}
    </div>
    {% endif %}

    {% if sidebarProducts %}
    <div class="sidebar-widget sidebar-affiliate-widget">
      <h4>Recommended Reading</h4>
      {%- for product in sidebarProducts %}
      <div class="sidebar-product">
        <a href="{{ product.url }}" target="_blank" rel="nofollow sponsored noopener" class="sidebar-product-title">{{ product.title }}</a>
        <p class="sidebar-product-author">{{ product.author }}</p>
      </div>
      {%- endfor %}
      <p class="sidebar-affiliate-note">Affiliate links — <a href="/affiliate-disclosure/">disclosure</a></p>
    </div>
    {% endif %}

    {% if sidebarShopPromo !== false %}
    <div class="sidebar-widget sidebar-shop-widget">
      <h4>Digital Resources</h4>
      <p style="font-size:0.9rem;margin-bottom:var(--sp-sm)">Zodiac forecasts, BaZi guides, feng shui checklists, and more.</p>
      <a href="/shop/" class="btn btn-gold btn-sm" style="width:100%;text-align:center">Browse Shop</a>
    </div>
    {% endif %}

    {% if site.adsenseEnabled and sidebarAd !== false %}
    <div class="sidebar-widget sidebar-ad-widget">
      {% set slot = sidebarAdSlot %}
      {% set format = "auto" %}
      {% include "partials/ad-unit.njk" %}
    </div>
    {% endif %}
  </aside>
  {% endif %}
</div>
