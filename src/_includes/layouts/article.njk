---js
{
  layout: "layouts/base.njk"
}
---
{% include "partials/breadcrumbs.njk" %}
{% include "partials/hero.njk" %}

<div class="article-layout">
  <article class="article-content">
    {% if showShareButtons !== false %}
      {% include "partials/share-buttons.njk" %}
    {% endif %}

    {{ content | safe }}

    {% if faq %}
    <section id="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-section">
        {%- for item in faq %}
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">{{ item.q }}</button>
          <div class="faq-answer">
            <p>{{ item.a }}</p>
          </div>
        </div>
        {%- endfor %}
      </div>
    </section>
    {% endif %}

    {% include "partials/content-upgrade.njk" %}

    {# --- Auto-generated inline related content (better for SEO than sidebar) --- #}
    {% set linkSource = autoRelated if (autoRelated and autoRelated.length) else relatedArticles %}
    {% if linkSource and linkSource.length %}
    <nav class="related-content" aria-labelledby="related-heading">
      <h2 id="related-heading"><span class="lang-en">Continue Exploring</span><span class="lang-tc">繼續探索</span><span class="lang-sc">继续探索</span></h2>
      <div class="related-grid">
        {%- for item in linkSource %}
        <a href="{{ item.url }}" class="related-card">
          <span class="related-card-label">{{ item.label }}</span>
          <span class="related-card-arrow">&rarr;</span>
        </a>
        {%- endfor %}
      </div>
    </nav>
    {% endif %}

    {% include "partials/comments.njk" %}
  </article>

  {% if sidebar !== false %}
  <aside class="article-sidebar">
    {% if toc %}
    <div class="sidebar-widget">
      <h3 class="sidebar-heading">Contents</h3>
      <ul class="toc-list">
        {%- for item in toc %}
        <li><a href="#{{ item.id }}">{{ item.label }}</a></li>
        {%- endfor %}
      </ul>
    </div>
    {% endif %}

    {% set sidebarLinks = relatedArticles if (relatedArticles and relatedArticles.length) else autoRelated %}
    {% if sidebarLinks and sidebarLinks.length %}
    <div class="sidebar-widget">
      <h3 class="sidebar-heading">Related</h3>
      {%- for item in sidebarLinks %}
      <a href="{{ item.url }}" style="display:block;margin-bottom:0.5rem;">{{ item.label }}</a>
      {%- endfor %}
    </div>
    {% endif %}

    {% if sidebarExplore %}
    <div class="sidebar-widget">
      <h3 class="sidebar-heading">Explore</h3>
      {%- for item in sidebarExplore %}
      <a href="{{ item.url }}" style="display:block;margin-bottom:0.5rem;">{{ item.label }}</a>
      {%- endfor %}
    </div>
    {% endif %}

    {% if sidebarProducts %}
    <div class="sidebar-widget sidebar-affiliate-widget">
      <h3 class="sidebar-heading">Recommended Reading</h3>
      {%- for product in sidebarProducts %}
      <div class="sidebar-product">
        <a href="{{ product.url }}" target="_blank" rel="nofollow sponsored noopener" class="sidebar-product-title">{{ product.title }}</a>
        <p class="sidebar-product-author">{{ product.author }}</p>
      </div>
      {%- endfor %}
      <p class="sidebar-affiliate-note">Affiliate links — <a href="/affiliate-disclosure/">disclosure</a></p>
    </div>
    <div class="sidebar-affiliate-disclosure">
      <p><strong>Disclosure:</strong> This page contains affiliate links. If you purchase through these links, we may earn a small commission at no extra cost to you. This supports our work bringing you authentic Chinese cultural content. <a href="/affiliate-disclosure/">Full disclosure &rarr;</a></p>
    </div>
    {% endif %}

    {% if sidebarShopPromo !== false %}
    <div class="sidebar-widget sidebar-shop-widget">
      <h3 class="sidebar-heading">Digital Resources</h3>
      <p style="font-size:0.9rem;margin-bottom:var(--sp-sm)">Zodiac forecasts, BaZi guides, feng shui checklists, and more.</p>
      <a href="/shop/" class="btn btn-gold btn-sm" style="width:100%;text-align:center">Browse Shop</a>
    </div>
    {% endif %}

    {% if site.adsenseEnabled and sidebarAd !== false %}
    <div class="sidebar-widget sidebar-ad-widget">
      {% set slot = sidebarAdSlot %}
      {% set format = "auto" %}
      {% include "partials/ad-unit.njk" %}
    </div>
    {% endif %}
  </aside>
  {% endif %}
</div>
