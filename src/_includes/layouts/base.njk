<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Canonical domain redirect: www → non-www (GitHub Pages cannot do server-level 301s) -->
  <script>if(location.hostname==='www.chinesezodiacyear.com')location.replace('https://chinesezodiacyear.com'+location.pathname+location.search+location.hash);</script>
  <title>{{ title }} | {{ site.name }}</title>
  <meta name="description" content="{{ description }}">
  {% if keywords %}<meta name="keywords" content="{{ keywords }}">{% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <!-- Favicon & Web Manifest -->
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#7D2018">
  <link rel="alternate" type="application/atom+xml" title="{{ site.name }} Feed" href="/feed.xml">
  <!-- Hreflang for trilingual content -->
  <link rel="alternate" hreflang="en" href="{{ site.url }}{{ page.url }}">
  <link rel="alternate" hreflang="zh-Hant" href="{{ site.url }}{{ page.url }}">
  <link rel="alternate" hreflang="zh-Hans" href="{{ site.url }}{{ page.url }}">
  <link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ page.url }}">
  {% if site.adsenseEnabled %}
  <meta name="google-adsense-account" content="{{ site.adsenseId }}">
  {% endif %}
  {% if site.pinterestVerification %}<meta name="p:domain_verify" content="{{ site.pinterestVerification }}">{% endif %}
  {% if site.bingVerification %}<meta name="msvalidate.01" content="{{ site.bingVerification }}">{% endif %}
  <!-- Pinterest Rich Pins -->
  <meta property="og:locale:alternate" content="zh_TW">
  <meta property="og:locale:alternate" content="zh_CN">
  <!-- Open Graph -->
  <meta property="og:type" content="{{ ogType | default('website') }}">
  <meta property="og:title" content="{{ ogTitle | default(title) }}">
  <meta property="og:description" content="{{ ogDescription | default(description) }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="en_US">
  {% set resolvedOgImage = ogImage | default('/img/og-default.png') %}
  {% if resolvedOgImage.startsWith('/') %}{% set resolvedOgImage = site.url + resolvedOgImage %}{% endif %}
  <meta property="og:image" content="{{ resolvedOgImage }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ ogTitle | default(title) }}">
  <meta name="twitter:description" content="{{ ogDescription | default(description) }}">
  <meta name="twitter:image" content="{{ resolvedOgImage }}">
  {% if site.twitterHandle %}<meta name="twitter:site" content="{{ site.twitterHandle }}">
  <meta name="twitter:creator" content="{{ site.twitterHandle }}">{% endif %}
  <!-- Fonts: Latin (deferred — avoids render-blocking) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Source+Sans+3:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Source+Sans+3:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Source+Sans+3:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet"></noscript>
  <!-- Fonts: CJK (deferred — heavy, only needed for Chinese content) -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&family=Noto+Serif+TC:wght@400;700&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&family=Noto+Serif+TC:wght@400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&family=Noto+Serif+TC:wght@400;700&display=swap" rel="stylesheet"></noscript>
  <link rel="stylesheet" href="/styles.css">
  {% if site.adsenseEnabled %}
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client={{ site.adsenseId }}" crossorigin="anonymous"></script>
  {% endif %}
  <script>(function(){var t=localStorage.getItem('czy-theme');if(t)document.documentElement.setAttribute('data-theme',t);var l=localStorage.getItem('czy-lang')||'en';document.documentElement.setAttribute('data-lang',l);var m={en:'en',tc:'zh-Hant',sc:'zh-Hans'};document.documentElement.setAttribute('lang',m[l]||'en')})()</script>
  {% if ogType == "article" %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"Article","headline":"{{ title | jsonLdSafe | safe }}","description":"{{ description | jsonLdSafe | safe }}","url":"{{ site.url }}{{ page.url }}","image":"{{ resolvedOgImage }}","datePublished":"{{ datePublished | default('2025-01-01') }}","dateModified":"{{ dateModified | default(datePublished) | default('2025-01-01') }}","author":{"@type":"Organization","name":"{{ site.name | jsonLdSafe | safe }}","url":"{{ site.url }}/"},"publisher":{"@type":"Organization","name":"{{ site.name | jsonLdSafe | safe }}","url":"{{ site.url }}/","logo":{"@type":"ImageObject","url":"{{ site.url }}/img/og-default.png"}},"mainEntityOfPage":{"@type":"WebPage","@id":"{{ site.url }}{{ page.url }}"},"inLanguage":"en"}</script>
  {% endif %}
  {% if breadcrumbs %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{% for crumb in breadcrumbs %}{"@type":"ListItem","position":{{ loop.index }},"name":"{{ crumb.label | jsonLdSafe | safe }}","item":"{{ site.url }}{% if crumb.url %}{{ crumb.url }}{% else %}{{ page.url }}{% endif %}"}{% if not loop.last %},{% endif %}{% endfor %}]}</script>
  {% endif %}
  {% if faq %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{% for item in faq %}{"@type":"Question","name":"{{ item.q | jsonLdSafe | safe }}","acceptedAnswer":{"@type":"Answer","text":"{{ item.a | jsonLdSafe | safe }}"}}{% if not loop.last %},{% endif %}{% endfor %}]}</script>
  {% endif %}
  {% if howTo %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"HowTo","name":"{{ howTo.name | jsonLdSafe | safe }}","description":"{{ howTo.description | jsonLdSafe | safe }}","step":[{% for step in howTo.steps %}{"@type":"HowToStep","position":{{ loop.index }},"name":"{{ step.name | jsonLdSafe | safe }}","text":"{{ step.text | jsonLdSafe | safe }}"}{% if not loop.last %},{% endif %}{% endfor %}]}</script>
  {% endif %}
  {% if shopSchema %}
  {% for product in shop.digitalProducts %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"Product","name":"{{ product.name | jsonLdSafe | safe }}","description":"{{ product.subtitle | jsonLdSafe | safe }}","url":"{{ product.gumroadUrl }}","image":"{{ resolvedOgImage }}","brand":{"@type":"Organization","name":"{{ site.name | jsonLdSafe | safe }}"},"offers":{"@type":"Offer","price":"{{ product.price }}","priceCurrency":"USD","availability":"https://schema.org/InStock","url":"{{ product.gumroadUrl }}"},"category":"Digital Download"}</script>
  {% endfor %}
  {% for reading in shop.premiumReadings %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"Product","name":"{{ reading.name | jsonLdSafe | safe }}","description":"{{ reading.description | jsonLdSafe | safe }}","url":"{{ reading.paypalLink }}","image":"{{ resolvedOgImage }}","brand":{"@type":"Organization","name":"{{ site.name | jsonLdSafe | safe }}"},"offers":{"@type":"Offer","price":"{{ reading.price }}","priceCurrency":"USD","availability":"https://schema.org/InStock","url":"{{ reading.paypalLink }}"},"category":"Professional Service"}</script>
  {% endfor %}
  {% endif %}
  {% if videos %}
  {% for video in videos %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"VideoObject","name":"{{ video.title | jsonLdSafe | safe }}","description":"{{ video.description | default(video.title) | jsonLdSafe | safe }}","thumbnailUrl":"https://img.youtube.com/vi/{{ video.id }}/maxresdefault.jpg","uploadDate":"{{ video.uploadDate | default(datePublished) | default('2025-01-01') }}","contentUrl":"https://www.youtube.com/watch?v={{ video.id }}","embedUrl":"https://www.youtube.com/embed/{{ video.id }}","publisher":{"@type":"Organization","name":"{{ site.name | jsonLdSafe | safe }}","url":"{{ site.url }}/"}}</script>
  {% endfor %}
  {% endif %}
  {% if directorySchema %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"ItemList","name":"{{ title | jsonLdSafe | safe }}","description":"{{ description | jsonLdSafe | safe }}","numberOfItems":{{ directory.listings | length }},"itemListElement":[{% for listing in directory.listings %}{"@type":"ListItem","position":{{ loop.index }},"item":{"@type":"{% if listing.category == 'tcm' %}MedicalBusiness{% elif listing.category == 'products' %}Store{% elif listing.category == 'martial-arts' %}SportsActivityLocation{% elif listing.category == 'culture' %}Organization{% else %}ProfessionalService{% endif %}","name":"{{ listing.name | jsonLdSafe | safe }}","description":"{{ listing.description | jsonLdSafe | safe }}"{% if listing.url %},"url":"{{ listing.url }}"{% endif %}{% if listing.location %},"address":{"@type":"PostalAddress","addressLocality":"{{ listing.location | jsonLdSafe | safe }}"}{% endif %}{% if listing.specialties %},"knowsAbout":[{% for s in listing.specialties %}"{{ s | jsonLdSafe | safe }}"{% if not loop.last %},{% endif %}{% endfor %}]{% endif %}}}{% if not loop.last %},{% endif %}{% endfor %}]}</script>
  {% endif %}
  {% if page.url == "/" %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"WebSite","name":"{{ site.name | jsonLdSafe | safe }}","alternateName":"ChineseZodiac","url":"{{ site.url }}/","description":"{{ site.description | jsonLdSafe | safe }}","potentialAction":{"@type":"SearchAction","target":"{{ site.url }}/search?q={search_term_string}","query-input":"required name=search_term_string"}}</script>
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"{{ site.name | jsonLdSafe | safe }}","url":"{{ site.url }}/","description":"Authoritative resource for Chinese zodiac, BaZi four pillars, feng shui, and Chinese cultural traditions rooted in classical pre-Qing scholarship."}</script>
  {% endif %}
  {% if site.ga4Id %}
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga4Id }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.ga4Id }}');
  </script>
  {% endif %}
</head>
<body>
  <a href="#main-content" class="skip-to-content">Skip to main content</a>
  {% include "partials/header.njk" %}

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "partials/newsletter.njk" %}
  {% include "partials/footer.njk" %}

  <script src="/site.js"></script>
  {% if page.url == "/" %}<script src="/trivia.js" defer></script>{% endif %}
</body>
</html>
