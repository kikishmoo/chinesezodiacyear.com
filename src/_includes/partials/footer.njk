<!-- ===== FOOTER ===== -->
<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">
    <div>
      <div class="footer-brand">{{ site.name }}</div>
      <p class="footer-desc">An independent editorial platform dedicated to preserving and sharing authentic Chinese astrological and cultural knowledge, grounded in classical pre-Qing scholarship.</p>
    </div>
    {%- for col in nav.footer %}
    <div class="footer-col">
      <h5>{{ col.heading }}</h5>
      {%- for link in col.links %}
      <a href="{{ link.url }}">{{ link.label }}</a>
      {%- endfor %}
    </div>
    {%- endfor %}
  </div>
  <div class="footer-bottom">
    <span>&copy; {{ site.year }} ChineseZodiacYear.com</span>
    <span>{{ site.tagline }}</span>
  </div>
</footer>
