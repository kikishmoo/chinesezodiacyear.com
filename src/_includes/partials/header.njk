<!-- ===== HEADER ===== -->
<header class="site-header" role="banner">
  <div class="header-inner">
    <a href="/" class="site-logo" aria-label="{{ site.name }} — Home">
      <div class="logo-seal" aria-hidden="true">生肖</div>
      <span class="lang-en">Chinese Zodiac</span><span class="lang-tc">中國生肖</span><span class="lang-sc">中国生肖</span>
    </a>
    <div class="header-toggles">
      <button class="lang-toggle" aria-label="Switch language" title="Switch language: English / 繁體中文 / 简体中文"><span class="lang-label-en">EN</span><span class="lang-label-tc">繁體</span><span class="lang-label-sc">简体</span></button>
      <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode"><span class="theme-icon-light">&#9788;</span><span class="theme-icon-dark">&#9790;</span></button>
    </div>
    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">&#9776;</button>
    <nav class="main-nav" role="navigation" aria-label="Primary">
      {%- for item in nav.primary %}
      <a href="{{ item.url }}"{% if page.fileSlug == item.page %} class="active"{% endif %}><span class="lang-en">{{ item.label }}</span><span class="lang-tc">{{ item.labelTc | default(item.label) }}</span><span class="lang-sc">{{ item.labelSc | default(item.label) }}</span></a>
      {%- endfor %}
      <div class="nav-dropdown">
        <button class="nav-dropdown-toggle"><span class="lang-en">More &#9662;</span><span class="lang-tc">更多 &#9662;</span><span class="lang-sc">更多 &#9662;</span></button>
        <div class="nav-dropdown-menu">
          {%- for item in nav.more %}
          <a href="{{ item.url }}"{% if page.fileSlug == item.page %} class="active"{% endif %}><span class="lang-en">{{ item.label }}</span><span class="lang-tc">{{ item.labelTc | default(item.label) }}</span><span class="lang-sc">{{ item.labelSc | default(item.label) }}</span></a>
          {%- endfor %}
        </div>
      </div>
      {%- for item in nav.secondary %}
      <a href="{{ item.url }}"{% if page.fileSlug == item.page %} class="active"{% endif %}><span class="lang-en">{{ item.label }}</span><span class="lang-tc">{{ item.labelTc | default(item.label) }}</span><span class="lang-sc">{{ item.labelSc | default(item.label) }}</span></a>
      {%- endfor %}
    </nav>
  </div>
</header>
