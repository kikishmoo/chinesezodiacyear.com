      <tr><td>Bing</td><td><span class="chinese-char">丙</span></td><td>Fire</td><td>Yang</td><td>Sun, brilliance, warmth, leadership</td></tr>
      <tr><td>Ding</td><td><span class="chinese-char">丁</span></td><td>Fire</td><td>Yin</td><td>Candle flame, focus, craftsmanship</td></tr>
      <tr><td>Wu</td><td><span class="chinese-char">戊</span></td><td>Earth</td><td>Yang</td><td>Mountain, immovability, reliability</td></tr>
