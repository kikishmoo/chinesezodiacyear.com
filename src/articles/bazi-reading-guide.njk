      <tr><td>劫財（<span class="chinese-char">劫財</span>）</td><td>同元素、異陰陽</td><td>競爭、被迫分享、驅動力</td></tr>
      <tr><td>食神（<span class="chinese-char">食神</span>）</td><td>我生之元素、同陰陽</td><td>創造力、表達、享樂</td></tr>
      <tr><td>傷官（<span class="chinese-char">傷官</span>）</td><td>我生之元素、異陰陽</td><td>叛逆、創新、才華</td></tr>
      <tr><td>正財（<span class="chinese-char">正財</span>）</td><td>我克之元素、異陰陽</td><td>穩定收入、妻子（男命）</td></tr>
      <tr><td>偏財（<span class="chinese-char">偏財</span>）</td><td>我克之元素、同陰陽</td><td>橫財、投機、父親</td></tr>
      <tr><td>正官（<span class="chinese-char">正官</span>）</td><td>克我之元素、異陰陽</td><td>權威、事業、丈夫（女命）</td></tr>
      <tr><td>七殺（<span class="chinese-char">七殺</span>）</td><td>克我之元素、同陰陽</td><td>壓力、危險、權力</td></tr>
