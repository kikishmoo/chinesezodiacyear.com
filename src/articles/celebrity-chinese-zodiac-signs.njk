      <tr><td>Vincent van Gogh</td><td>1853</td><td>Water Ox (<span class="chinese-char">癸丑</span>)</td><td>Post-Impressionist painter &mdash; produced over 2,000 works in a decade</td></tr>
      <tr><td>Walt Disney</td><td>1901</td><td>Metal Ox (<span class="chinese-char">辛丑</span>)</td><td>Animator, film producer, theme park pioneer</td></tr>
