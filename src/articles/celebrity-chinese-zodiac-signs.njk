      <tr><td>Amelia Earhart</td><td>1897</td><td>Fire Rooster (<span class="chinese-char">丁酉</span>)</td><td>Aviator &mdash; first woman to fly solo across the Atlantic</td></tr>
      <tr><td>Katharine Hepburn</td><td>1907</td><td>Fire Rooster (<span class="chinese-char">丁酉</span>)</td><td>Actress &mdash; record four Academy Awards, Hollywood legend</td></tr>
