      <tr><td>Wolfgang Amadeus Mozart</td><td>1756</td><td>Fire Rat (<span class="chinese-char">丙子</span>)</td><td>Composer &mdash; prodigious musical genius of the Classical era</td></tr>
      <tr><td>Leo Tolstoy</td><td>1828</td><td>Earth Rat (<span class="chinese-char">戊子</span>)</td><td>Novelist &mdash; author of <em>War and Peace</em> and <em>Anna Karenina</em></td></tr>
