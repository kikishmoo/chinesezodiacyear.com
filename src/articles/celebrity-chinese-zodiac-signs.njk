      <tr><td>Ernest Hemingway</td><td>1899</td><td>Earth Pig (<span class="chinese-char">己亥</span>)</td><td>Author &mdash; <em>The Old Man and the Sea</em>, Nobel Prize in Literature</td></tr>
      <tr><td>Alfred Hitchcock</td><td>1899</td><td>Earth Pig (<span class="chinese-char">己亥</span>)</td><td>Film director &mdash; the "Master of Suspense"</td></tr>
      <tr><td>Ronald Reagan</td><td>1911</td><td>Metal Pig (<span class="chinese-char">辛亥</span>)</td><td>40th President of the United States, former Hollywood actor</td></tr>
