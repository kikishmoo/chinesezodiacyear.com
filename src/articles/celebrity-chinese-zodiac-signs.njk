      <tr><td>Elvis Presley</td><td>1935</td><td>Wood Dog (<span class="chinese-char">乙戌</span>)</td><td>Singer, actor &mdash; the "King of Rock and Roll"</td></tr>
      <tr><td>Michael Jackson</td><td>1958</td><td>Earth Dog (<span class="chinese-char">戊戌</span>)</td><td>Singer, dancer &mdash; the "King of Pop"</td></tr>
      <tr><td>Prince William</td><td>1982</td><td>Water Dog (<span class="chinese-char">壬戌</span>)</td><td>Prince of Wales, heir to the British throne</td></tr>
      <tr><td>Jennifer Lawrence</td><td>1990</td><td>Metal Dog (<span class="chinese-char">庚戌</span>)</td><td>Actress &mdash; youngest to earn four Academy Award nominations</td></tr>
