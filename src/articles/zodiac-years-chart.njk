    <thead>
      <tr><th>Stem</th><th>Chinese</th><th>Element</th><th>Polarity</th></tr>
    </thead>
    <tbody>
      <tr><td>Ji&#462;</td><td><span class="chinese-char">甲</span></td><td>Wood</td><td>Yang</td></tr>
      <tr><td>Y&#464;</td><td><span class="chinese-char">乙</span></td><td>Wood</td><td>Yin</td></tr>
      <tr><td>B&#464;ng</td><td><span class="chinese-char">丙</span></td><td>Fire</td><td>Yang</td></tr>
