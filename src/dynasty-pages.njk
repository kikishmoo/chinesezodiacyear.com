---
pagination:
  data: dynastiesData
  size: 1
  alias: dynasty
  addAllPagesToCollections: true
permalink: "/dynasties/{{ dynasty.slug }}/"
layout: "layouts/article.njk"
ogType: "article"
category: "encyclopedia"
eleventyComputed:
  title: "{{ dynasty.name }} ({{ dynasty.nameTc }}) — History & Culture"
  description: "The {{ dynasty.name }} ({{ dynasty.nameTc }}, {{ dynasty.dates }}): history, cultural contributions, and significance to Chinese zodiac, calendar, and metaphysical traditions."
  keywords: "{{ dynasty.name }}, {{ dynasty.nameTc }}, {{ dynasty.pinyin }}, Chinese dynasty, {{ dynasty.dates }}, Chinese history"
  heroOverline: "Dynasties"
  heroTitle: "{{ dynasty.name }}"
  heroSubtitle: "{{ dynasty.nameTc }} · {{ dynasty.dates }}"
  toc:
    - id: "overview"
      label: "Overview"
    - id: "capital"
      label: "Capital & Period"
    - id: "contributions"
      label: "Key Contributions"
    - id: "faq"
      label: "FAQ"
tags: ["dynasty"]
---

<section id="overview">
  <h2><span class="lang-en">{{ dynasty.name }} — {{ dynasty.nameTc }}</span><span class="lang-tc">{{ dynasty.nameTc }} — {{ dynasty.name }}</span><span class="lang-sc">{{ dynasty.nameSc }} — {{ dynasty.name }}</span></h2>
  <p class="subtitle" style="font-style:italic;">{{ dynasty.pinyin }} · {{ dynasty.dates }}</p>

  <div class="key-facts" role="region" aria-label="Key facts">
    <h3 class="key-facts-title"><span class="lang-en">Key Facts</span><span class="lang-tc">重點</span><span class="lang-sc">重点</span></h3>
    <dl class="key-facts-list">
      <div class="key-facts-item"><dt><span class="lang-en">Dynasty</span><span class="lang-tc">朝代</span><span class="lang-sc">朝代</span></dt><dd>{{ dynasty.name }} ({{ dynasty.nameTc }}, {{ dynasty.pinyin }})</dd></div>
      <div class="key-facts-item"><dt><span class="lang-en">Period</span><span class="lang-tc">時期</span><span class="lang-sc">时期</span></dt><dd>{{ dynasty.dates }}</dd></div>
      <div class="key-facts-item"><dt><span class="lang-en">Capital</span><span class="lang-tc">都城</span><span class="lang-sc">都城</span></dt><dd>{{ dynasty.capital }}</dd></div>
      <div class="key-facts-item"><dt><span class="lang-en">Notable for</span><span class="lang-tc">著名貢獻</span><span class="lang-sc">著名贡献</span></dt><dd>{{ dynasty.keyContributions | first }}</dd></div>
    </dl>
  </div>

  <p><span class="lang-en">{{ dynasty.description }}</span><span class="lang-tc">{{ dynasty.descriptionTc }}</span><span class="lang-sc">{{ dynasty.descriptionSc }}</span></p>
</section>

<section id="capital">
  <h2><span class="lang-en">Capital &amp; Period</span><span class="lang-tc">都城與時期</span><span class="lang-sc">都城与时期</span></h2>
  <div class="info-grid" style="margin-top:var(--sp-lg);">
    <div class="info-card">
      <span class="info-card-icon">🏯</span>
      <div class="info-card-value">{{ dynasty.capital }}</div>
      <div class="info-card-label"><span class="lang-en">Capital</span><span class="lang-tc">都城</span><span class="lang-sc">都城</span></div>
    </div>
    <div class="info-card">
      <span class="info-card-icon">📜</span>
      <div class="info-card-value">{{ dynasty.dates }}</div>
      <div class="info-card-label"><span class="lang-en">Period</span><span class="lang-tc">時期</span><span class="lang-sc">时期</span></div>
    </div>
  </div>
</section>

<section id="contributions">
  <h2><span class="lang-en">Key Contributions</span><span class="lang-tc">主要貢獻</span><span class="lang-sc">主要贡献</span></h2>
  <p><span class="lang-en">The {{ dynasty.name }} made lasting contributions to Chinese zodiac, calendar, and metaphysical traditions:</span><span class="lang-tc">{{ dynasty.nameTc }}對中國生肖、曆法和形而上學傳統做出了持久貢獻：</span><span class="lang-sc">{{ dynasty.nameSc }}对中国生肖、历法和形而上学传统做出了持久贡献：</span></p>
  <ul class="feature-list" style="margin-top:var(--sp-md);">
    {%- for contribution in dynasty.keyContributions %}
    <li>{{ contribution }}</li>
    {%- endfor %}
  </ul>
</section>

{%- if dynasty.relatedContent and dynasty.relatedContent.length > 0 %}
<section id="related-content">
  <h2><span class="lang-en">Related Content</span><span class="lang-tc">相關內容</span><span class="lang-sc">相关内容</span></h2>
  <p><span class="lang-en">Explore topics connected to the {{ dynasty.name }}:</span><span class="lang-tc">探索與{{ dynasty.nameTc }}相關的主題：</span><span class="lang-sc">探索与{{ dynasty.nameSc }}相关的主题：</span></p>

  {%- for item in dynasty.relatedContent %}
  <div class="callout-box callout-box--jade" style="margin-top:var(--sp-lg);">
    <div class="callout-icon">📖</div>
    <div class="callout-content">
      <h3><span class="lang-en">{{ item.title }}</span><span class="lang-tc">{{ item.titleTc }}</span><span class="lang-sc">{{ item.titleSc }}</span></h3>
      <p><span class="lang-en">{{ item.text | safe }}</span><span class="lang-tc">{{ item.textTc | safe }}</span><span class="lang-sc">{{ item.textSc | safe }}</span></p>
      <p style="margin-top:var(--sp-sm);"><a href="{{ item.link }}"><span class="lang-en">{{ item.linkLabel }}</span><span class="lang-tc">{{ item.linkLabelTc }}</span><span class="lang-sc">{{ item.linkLabelSc }}</span></a></p>
    </div>
  </div>
  {%- endfor %}
</section>
{%- endif %}
