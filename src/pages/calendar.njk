<section id="introduction">
      <h2>Introduction to the Chinese Calendar</h2>

      <div class="image-panel">
        <img src="https://images.unsplash.com/photo-1741768279222-02bde9dc89d6?w=1200&h=400&fit=crop" alt="Terraced rice fields illustrating agricultural calendar traditions" loading="lazy">
