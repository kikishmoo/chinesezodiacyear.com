---
layout: "layouts/base.njk"
title: "Directory — Feng Shui, BaZi & Chinese Culture Practitioners"
description: "Directory of feng shui consultants, BaZi practitioners, TCM clinics, martial arts schools, and Chinese cultural organizations worldwide."
keywords: "feng shui consultant directory, BaZi practitioner, TCM clinic, martial arts school, Chinese cultural organizations, zodiac professionals"
ogType: "website"
permalink: "/directory/"
breadcrumbs:
  - label: "Home"
    url: "/"
  - label: "Directory"
---
{% include "partials/breadcrumbs.njk" %}

<section class="page-hero">
  <div class="page-hero-content">
    <span class="overline">Community</span>
    <h1>Professional Directory</h1>
    <p class="subtitle">Feng shui consultants, BaZi practitioners, cultural organisations, TCM clinics, martial arts schools, and more</p>
  </div>
</section>

<div class="directory-layout">
    <div class="directory-controls">
      <input type="text" id="directory-search" class="directory-search" placeholder="Search listings by name, location, or speciality&hellip;">
      <div class="directory-filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="fengshui">Feng Shui</button>
        <button class="filter-btn" data-filter="bazi">BaZi</button>
        <button class="filter-btn" data-filter="culture">Cultural Orgs</button>
        <button class="filter-btn" data-filter="products">Products &amp; Shops</button>
        <button class="filter-btn" data-filter="tcm">TCM</button>
        <button class="filter-btn" data-filter="martial-arts">Martial Arts</button>
      </div>
    </div>

    <div class="directory-grid">

      {% for item in directory.listings %}
      <div class="directory-card{% if item.featured %} directory-card--featured{% endif %}" data-category="{{ item.category }}">
        <div class="directory-card-header">
          <h3>{% if item.url %}<a href="{{ item.url }}" target="_blank" rel="noopener nofollow">{{ item.name }}</a>{% else %}{{ item.name }}{% endif %}</h3>
          <span class="directory-badge badge-{{ item.category }}">{{ item.badge }}</span>
        </div>
        <p>{{ item.description }}</p>
        <div class="directory-details">
          <span class="directory-location">{{ item.location }}</span>
          <span class="directory-specialties">{{ item.specialties | join(" · ") }}</span>
        </div>
      </div>
      {% endfor %}

    </div>

    <div class="directory-cta">
      <h3>List Your Organisation</h3>
      <p>Are you a feng shui consultant, BaZi practitioner, TCM clinic, or cultural organisation? <a href="/about/">Contact us</a> to be included in our directory.</p>
    </div>

</div>
