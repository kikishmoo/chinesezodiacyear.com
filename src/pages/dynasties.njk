    <section id="timeline">
      <h2>Dynasty Timeline</h2>
      <div class="timeline">
        <div class="timeline-item"><h3>Xia (<span class="chinese-char">夏</span>) — c. 2070–1600 BCE</h3><p>Calendar origins, bronze age</p></div>
        <div class="timeline-item"><h3>Shang (<span class="chinese-char">商</span>) — c. 1600–1046 BCE</h3><p>Oracle bones, writing, Stems & Branches</p></div>
        <div class="timeline-item"><h3>Western Zhou (<span class="chinese-char">西周</span>) — 1046–771 BCE</h3><p>Yi Jing, ritual system, Mandate of Heaven</p></div>
        <div class="timeline-item"><h3>Eastern Zhou (<span class="chinese-char">東周</span>) — 771–256 BCE</h3><p>Hundred Schools of Thought, Five Elements</p></div>
        <div class="timeline-item"><h3>Qin (<span class="chinese-char">秦</span>) — 221–206 BCE</h3><p>Unification, standardisation, zodiac evidence</p></div>
        <div class="timeline-item"><h3>Han (<span class="chinese-char">漢</span>) — 206 BCE–220 CE</h3><p>Calendar reform, Silk Road, Huangdi Neijing</p></div>
        <div class="timeline-item"><h3>Three Kingdoms (<span class="chinese-char">三國</span>) — 220–280 CE</h3><p>Zhang Zhongjing, Hua Tuo, literary romance</p></div>
        <div class="timeline-item"><h3>Tang (<span class="chinese-char">唐</span>) — 618–907 CE</h3><p>BaZi origins, poetry, Chan Buddhism, printing</p></div>
        <div class="timeline-item"><h3>Song (<span class="chinese-char">宋</span>) — 960–1279 CE</h3><p>BaZi perfected, Neo-Confucianism, Four Inventions</p></div>
        <div class="timeline-item"><h3>Yuan (<span class="chinese-char">元</span>) — 1271–1368 CE</h3><p>Drama, Shoushi calendar, agricultural texts</p></div>
        <div class="timeline-item"><h3>Ming (<span class="chinese-char">明</span>) — 1368–1644 CE</h3><p>Hanfu revival, Bencao Gangmu, Zheng He</p></div>
      </div>
