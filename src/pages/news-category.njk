      <a href="/news/culture/" class="filter-btn{% if cat.slug == 'culture' %} active{% endif %}">文化</a>
      <a href="/news/fengshui/" class="filter-btn{% if cat.slug == 'fengshui' %} active{% endif %}">風水</a>
      <a href="/news/bazi/" class="filter-btn{% if cat.slug == 'bazi' %} active{% endif %}">八字</a>
      <a href="/news/business/" class="filter-btn{% if cat.slug == 'business' %} active{% endif %}">商業</a>
