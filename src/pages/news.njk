---
layout: "layouts/base.njk"
title: "News & Articles"
description: "Latest articles on Chinese zodiac predictions, feng shui guidance, BaZi analysis, cultural heritage, and traditional Chinese astrology news."
keywords: "Chinese zodiac news, feng shui articles, BaZi analysis, Chinese astrology updates, cultural heritage news, zodiac predictions"
ogType: "website"
category: "news"
pagination:
  data: collections.articles
  size: 6
  alias: paginatedArticles
  generatePageOnEmptyData: false
permalink: "/news/{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}"
eleventyComputed:
  breadcrumbs:
    - label: "Home"
      url: "/"
    - label: "News & Articles"
---
{% include "partials/breadcrumbs.njk" %}

{# ===== ENGLISH ===== #}
<div class="lang-en">
<section class="page-hero">
  <div class="page-hero-content">
    <span class="overline">Latest</span>
    <h1>News &amp; Articles{% if pagination.pageNumber > 0 %} &mdash; Page {{ pagination.pageNumber + 1 }}{% endif %}</h1>
    <p class="subtitle">Analysis, commentary, and guides on Chinese zodiac, feng shui, BaZi, and cultural traditions</p>
  </div>
</section>

<div class="news-layout">
    <div class="news-filters">
      <a href="/news/" class="filter-btn active">All</a>
      <a href="/news/zodiac/" class="filter-btn">Zodiac</a>
      <a href="/news/culture/" class="filter-btn">Culture</a>
      <a href="/news/fengshui/" class="filter-btn">Feng Shui</a>
      <a href="/news/bazi/" class="filter-btn">BaZi</a>
      <a href="/news/business/" class="filter-btn">Business</a>
    </div>

    <div class="articles-grid">
      {%- for article in paginatedArticles %}
      <article class="article-card" data-category="{{ article.data.category }}">
        <div class="article-card-body">
          <div class="article-meta">
            <span class="article-tag tag-{{ article.data.category }}">{{ article.data.categoryLabel }}</span>
            <time datetime="{{ article.data.date | isoDate }}">{{ article.data.date | readableDate }}</time>
          </div>
          <h2><a href="{{ article.url }}">{{ article.data.title }}</a></h2>
          <p>{{ article.data.description }}</p>
          <span class="read-more">Read article &rarr;</span>
        </div>
      </article>
      {%- endfor %}
    </div>

    {% if pagination.pages.length > 1 %}
    <nav class="pagination-nav" aria-label="News pagination">
      {% if pagination.href.previous %}
        <a href="{{ pagination.href.previous }}" class="pagination-link pagination-prev">&larr; Newer</a>
      {% else %}
        <span class="pagination-link pagination-prev disabled">&larr; Newer</span>
      {% endif %}
      <span class="pagination-info">Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>
      {% if pagination.href.next %}
        <a href="{{ pagination.href.next }}" class="pagination-link pagination-next">Older &rarr;</a>
      {% else %}
        <span class="pagination-link pagination-next disabled">Older &rarr;</span>
      {% endif %}
    </nav>
    {% endif %}
</div>
</div>

