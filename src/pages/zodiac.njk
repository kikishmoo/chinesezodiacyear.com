              <tr><td>马</td><td>大势至菩萨</td><td><span class="chinese-char">大势至菩萨</span></td><td><span class="pinyin">Dàshìzhì Púsà</span></td></tr>
              <tr><td>羊、猴</td><td>大日如来</td><td><span class="chinese-char">大日如来</span></td><td><span class="pinyin">Dàrì Rúlái</span></td></tr>
              <tr><td>鸡</td><td>不动明王</td><td><span class="chinese-char">不动明王</span></td><td><span class="pinyin">Búdòng Míngwáng</span></td></tr>
              <tr><td>狗、猪</td><td>阿弥陀佛</td><td><span class="chinese-char">阿弥陀佛</span></td><td><span class="pinyin">Āmítuó Fó</span></td></tr>
