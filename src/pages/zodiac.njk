              <tr><td>牛、虎</td><td>虚空藏菩萨</td><td><span class="chinese-char">虚空藏菩萨</span></td><td><span class="pinyin">Xūkōngzàng Púsà</span></td></tr>
              <tr><td>兔</td><td>文殊菩萨</td><td><span class="chinese-char">文殊菩萨</span></td><td><span class="pinyin">Wénshū Púsà</span></td></tr>
