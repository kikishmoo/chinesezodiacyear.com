---
pagination:
  data: elements
  size: 1
  alias: element
  addAllPagesToCollections: true
permalink: "/wuxing/{{ element.slug }}/"
layout: "layouts/article.njk"
ogType: "article"
category: "encyclopedia"
eleventyComputed:
  title: "{{ element.name }} Element ({{ element.nameTc }}) — Wu Xing"
  description: "The {{ element.name }} element ({{ element.nameTc }}, {{ element.pinyin }}) in Chinese five-element theory: direction, season, organs, generating and overcoming cycles, and associated zodiac animals."
  keywords: "{{ element.name }} element, Wu Xing {{ element.name }}, Chinese five elements, {{ element.nameTc }}, {{ element.pinyin }}, {{ element.name }} zodiac"
  heroOverline: "Wu Xing — Five Elements"
  heroTitle: "{{ element.name }} — {{ element.nameTc }}"
  heroSubtitle: "{{ element.direction }} · {{ element.season }} · {{ element.color }}"
  breadcrumbs:
    - label: "Home"
      url: "/"
    - label: "Wu Xing"
      url: "/wuxing/"
    - label: "{{ element.name }}"
  toc:
    - id: "overview"
      label: "Overview"
    - id: "correspondences"
      label: "Correspondences"
    - id: "cycles"
      label: "Generating & Overcoming Cycles"
    - id: "animals"
      label: "Associated Animals"
    - id: "faq"
      label: "FAQ"
tags: ["element"]
---

<section id="overview">
  <h2><span class="lang-en">{{ element.name }} — {{ element.nameTc }}</span><span class="lang-tc">{{ element.nameTc }} — {{ element.name }}</span><span class="lang-sc">{{ element.nameSc }} — {{ element.name }}</span></h2>
  <p class="subtitle" style="font-style:italic;">{{ element.pinyin }}</p>

  <div class="key-facts" role="region" aria-label="Key facts">
    <h3 class="key-facts-title"><span class="lang-en">Key Facts</span><span class="lang-tc">重點</span><span class="lang-sc">重点</span></h3>
    <dl class="key-facts-list">
      <div class="key-facts-item"><dt><span class="lang-en">Element</span><span class="lang-tc">五行</span><span class="lang-sc">五行</span></dt><dd>{{ element.name }} ({{ element.nameTc }}, {{ element.pinyin }})</dd></div>
      <div class="key-facts-item"><dt><span class="lang-en">Direction</span><span class="lang-tc">方位</span><span class="lang-sc">方位</span></dt><dd>{{ element.direction }}</dd></div>
      <div class="key-facts-item"><dt><span class="lang-en">Season</span><span class="lang-tc">季節</span><span class="lang-sc">季节</span></dt><dd>{{ element.season }}</dd></div>
      <div class="key-facts-item"><dt><span class="lang-en">Colour</span><span class="lang-tc">顏色</span><span class="lang-sc">颜色</span></dt><dd>{{ element.color }}</dd></div>
      <div class="key-facts-item"><dt><span class="lang-en">Yin Organ</span><span class="lang-tc">陰臟</span><span class="lang-sc">阴脏</span></dt><dd>{{ element.yinOrgan }}</dd></div>
      <div class="key-facts-item"><dt><span class="lang-en">Generates</span><span class="lang-tc">生</span><span class="lang-sc">生</span></dt><dd>{{ element.generates }}</dd></div>
      <div class="key-facts-item"><dt><span class="lang-en">Zodiac Animals</span><span class="lang-tc">生肖</span><span class="lang-sc">生肖</span></dt><dd>{{ element.animals | join(', ') }}</dd></div>
    </dl>
  </div>

  <p><span class="lang-en">{{ element.description }}</span><span class="lang-tc">{{ element.descriptionTc }}</span><span class="lang-sc">{{ element.descriptionSc }}</span></p>
</section>

<section id="correspondences">
  <h2><span class="lang-en">Classical Correspondences</span><span class="lang-tc">古典對應</span><span class="lang-sc">古典对应</span></h2>
  <div class="info-grid" style="margin-top:var(--sp-lg);">
    <div class="info-card">
      <span class="info-card-icon">🧭</span>
      <div class="info-card-value">{{ element.direction }}</div>
      <div class="info-card-label"><span class="lang-en">Direction</span><span class="lang-tc">方位</span><span class="lang-sc">方位</span></div>
    </div>
    <div class="info-card">
      <span class="info-card-icon">🌿</span>
      <div class="info-card-value">{{ element.season }}</div>
      <div class="info-card-label"><span class="lang-en">Season</span><span class="lang-tc">季節</span><span class="lang-sc">季节</span></div>
    </div>
    <div class="info-card">
      <span class="info-card-icon">🎨</span>
      <div class="info-card-value">{{ element.color }}</div>
      <div class="info-card-label"><span class="lang-en">Colour</span><span class="lang-tc">顏色</span><span class="lang-sc">颜色</span></div>
    </div>
    <div class="info-card">
      <span class="info-card-icon">🪐</span>
      <div class="info-card-value">{{ element.planet }}</div>
      <div class="info-card-label"><span class="lang-en">Planet</span><span class="lang-tc">星球</span><span class="lang-sc">星球</span></div>
    </div>
  </div>

  <table class="data-table" style="margin-top:var(--sp-xl);">
    <thead>
      <tr>
        <th><span class="lang-en">Attribute</span><span class="lang-tc">屬性</span><span class="lang-sc">属性</span></th>
        <th><span class="lang-en">Correspondence</span><span class="lang-tc">對應</span><span class="lang-sc">对应</span></th>
      </tr>
    </thead>
    <tbody>
      <tr><td><span class="lang-en">Yin Organ</span><span class="lang-tc">陰臟</span><span class="lang-sc">阴脏</span></td><td>{{ element.yinOrgan }}</td></tr>
      <tr><td><span class="lang-en">Yang Organ</span><span class="lang-tc">陽腑</span><span class="lang-sc">阳腑</span></td><td>{{ element.yangOrgan }}</td></tr>
      <tr><td><span class="lang-en">Taste</span><span class="lang-tc">味</span><span class="lang-sc">味</span></td><td>{{ element.taste }}</td></tr>
      <tr><td><span class="lang-en">Emotion</span><span class="lang-tc">情志</span><span class="lang-sc">情志</span></td><td>{{ element.emotion }}</td></tr>
      <tr><td><span class="lang-en">Planet</span><span class="lang-tc">星</span><span class="lang-sc">星</span></td><td>{{ element.planet }}</td></tr>
    </tbody>
  </table>
</section>

<section id="cycles">
  <h2><span class="lang-en">Generating &amp; Overcoming Cycles</span><span class="lang-tc">相生相剋</span><span class="lang-sc">相生相克</span></h2>
  <div class="info-grid" style="margin-top:var(--sp-lg);">
    <div class="info-card">
      <span class="info-card-icon">✨</span>
      <div class="info-card-value">{{ element.generates }}</div>
      <div class="info-card-label"><span class="lang-en">{{ element.name }} Generates</span><span class="lang-tc">{{ element.nameTc }}生</span><span class="lang-sc">{{ element.nameSc }}生</span></div>
    </div>
    <div class="info-card">
      <span class="info-card-icon">💧</span>
      <div class="info-card-value">{{ element.generatedBy }}</div>
      <div class="info-card-label"><span class="lang-en">Generated By</span><span class="lang-tc">生{{ element.nameTc }}</span><span class="lang-sc">生{{ element.nameSc }}</span></div>
    </div>
    <div class="info-card">
      <span class="info-card-icon">⚔️</span>
      <div class="info-card-value">{{ element.overcomes }}</div>
      <div class="info-card-label"><span class="lang-en">{{ element.name }} Overcomes</span><span class="lang-tc">{{ element.nameTc }}剋</span><span class="lang-sc">{{ element.nameSc }}克</span></div>
    </div>
    <div class="info-card">
      <span class="info-card-icon">🛡️</span>
      <div class="info-card-value">{{ element.overcomeBy }}</div>
      <div class="info-card-label"><span class="lang-en">Overcome By</span><span class="lang-tc">剋{{ element.nameTc }}</span><span class="lang-sc">克{{ element.nameSc }}</span></div>
    </div>
  </div>
</section>

<section id="animals">
  <h2><span class="lang-en">Associated Zodiac Animals</span><span class="lang-tc">相關生肖</span><span class="lang-sc">相关生肖</span></h2>
  <p><span class="lang-en">The following zodiac animals have {{ element.name }} as their fixed element:</span><span class="lang-tc">以下生肖以{{ element.nameTc }}為固定五行：</span><span class="lang-sc">以下生肖以{{ element.nameSc }}为固定五行：</span></p>
  <div class="reading-grid" style="max-width:600px;margin:var(--sp-lg) 0;">
    {%- for animal in element.animals %}
    {% set animalSlug = animal | lower %}
    <a href="/zodiac/{{ animalSlug }}/" class="reading-card">
      <span class="reading-card-name">{{ animal }}</span>
    </a>
    {%- endfor %}
  </div>
</section>
